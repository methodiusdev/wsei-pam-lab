<androidx.gridlayout.widget.GridLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/favorites_grid"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="@dimen/inner_margin"
    app:columnCount="3"
    app:useDefaultMargins="true">

    <Button
        android:id="@+id/main_6_6_board"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="6 x 6"
        android:tag="6 6"
        android:textSize="34sp"
        android:onClick="onButtonClick"
        app:icon="@drawable/ic_puzzle"
        app:iconGravity="textTop"
        app:iconPadding="@dimen/icon_padding"
        app:iconSize="48dp"
        app:layout_columnWeight="1"
        app:layout_rowWeight="1" />

    <Space
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:minWidth="@dimen/inner_margin"/>

    <Button
        android:id="@+id/main_4_4_board"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="4 x 4"
        android:tag="4 4"
        android:textSize="34sp"
        android:onClick="onButtonClick"
        app:icon="@drawable/ic_puzzle"
        app:iconGravity="textTop"
        app:iconPadding="@dimen/icon_padding"
        app:iconSize="48dp"
        app:layout_columnWeight="1"
        app:layout_rowWeight="1" />


    <Button
        android:id="@+id/main_4_3_board"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="4 x 3"
        android:tag="4 3"
        android:textSize="34sp"
        android:onClick="onButtonClick"
        app:icon="@drawable/ic_puzzle"
        app:iconGravity="textTop"
        app:iconPadding="@dimen/icon_padding"
        app:iconSize="48dp"
        app:layout_columnWeight="1"
        app:layout_rowWeight="1" />

    <Space
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:minWidth="@dimen/inner_margin"/>

    <Button
        android:id="@+id/main_3_2_board"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="3 x 2"
        android:tag="3 2"
        android:textSize="34sp"
        android:onClick="onButtonClick"
        app:icon="@drawable/ic_puzzle"
        app:iconGravity="textTop"
        app:iconPadding="@dimen/icon_padding"
        app:iconSize="48dp"
        app:layout_columnWeight="1"
        app:layout_rowWeight="1" />
</androidx.gridlayout.widget.GridLayout>